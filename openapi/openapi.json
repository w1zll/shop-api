  "info": {
    "title": "Shop API",
    "description": "API демонстрационного магазина на микрофронтендах",
    "version": "0.1.0",
    "contact": {}
  },
  "tags": [],
  "servers": [],
  "components": {
    "securitySchemes": {
      "cookie": { "type": "apiKey", "in": "cookie", "name": "access_token" }
    },
    "schemas": {
      "CategoryDto": {
        "type": "object",
        "properties": {
          "id": { "type": "string" },
          "name": { "type": "string" },
          "slug": { "type": "string" },
          "description": { "type": "object", "nullable": true },
          "imageUrl": { "type": "object", "nullable": true },
          "parentId": { "type": "object", "nullable": true },
          "productsCount": { "type": "number" }
        },
        "required": ["id", "name", "slug", "productsCount"]
      },
      "ProductCategoryDto": {
        "type": "object",
        "properties": {
          "id": { "type": "string" },
          "name": { "type": "string" },
          "slug": { "type": "string" }
        },
        "required": ["id", "name", "slug"]
      },
      "ProductImageDto": {
        "type": "object",
        "properties": {
          "id": { "type": "string" },
          "url": { "type": "string" },
          "alt": { "type": "string" },
          "position": { "type": "number" }
        },
        "required": ["id", "url", "alt", "position"]
      },
      "ProductDto": {
        "type": "object",
        "properties": {
          "id": { "type": "string" },
          "name": { "type": "string" },
          "slug": { "type": "string" },
          "description": { "type": "string" },
          "brand": { "type": "string" },
          "priceCents": { "type": "number" },
          "oldPriceCents": { "type": "object", "nullable": true },
          "stock": { "type": "number" },
          "isFeatured": { "type": "boolean" },
          "attributes": { "type": "object" },
          "category": { "$ref": "#/components/schemas/ProductCategoryDto" },
          "images": {
            "type": "array",
            "items": { "$ref": "#/components/schemas/ProductImageDto" }
          }
        },
        "required": [
          "id",
          "name",
          "slug",
          "description",
          "brand",
          "priceCents",
          "stock",
          "isFeatured",
          "attributes",
          "category",
          "images"
        ]
      },
      "PaginationDto": {
        "type": "object",
        "properties": {
          "page": { "type": "number" },
          "limit": { "type": "number" },
          "total": { "type": "number" },
          "totalPages": { "type": "number" }
        },
        "required": ["page", "limit", "total", "totalPages"]
      },
      "AvailableFiltersDto": {
        "type": "object",
        "properties": {
          "brands": { "type": "array", "items": { "type": "string" } },
          "minPriceCents": { "type": "object", "nullable": true },
          "maxPriceCents": { "type": "object", "nullable": true },
          "hasInStock": { "type": "boolean" }
        },
        "required": ["brands", "hasInStock"]
      },
      "ProductListDto": {
        "type": "object",
        "properties": {
          "items": {
            "type": "array",
            "items": { "$ref": "#/components/schemas/ProductDto" }
          },
          "pagination": { "$ref": "#/components/schemas/PaginationDto" },
          "availableFilters": {
            "$ref": "#/components/schemas/AvailableFiltersDto"
          }
        },
        "required": ["items", "pagination", "availableFilters"]
      },
      "FeaturedProductsDto": {
        "type": "object",
        "properties": {
          "items": {
            "type": "array",
            "items": { "$ref": "#/components/schemas/ProductDto" }
          }
        },
        "required": ["items"]
      },
      "SearchSuggestionDto": {
        "type": "object",
        "properties": {
          "label": { "type": "string" },
          "slug": { "type": "string" },
          "brand": { "type": "string" }
        },
        "required": ["label", "slug", "brand"]
      },
      "SearchSuggestionsDto": {
        "type": "object",
        "properties": {
          "items": {
            "type": "array",
            "items": { "$ref": "#/components/schemas/SearchSuggestionDto" }
          }
        },
        "required": ["items"]
      },
      "CartProductDto": {
        "type": "object",
        "properties": {
          "id": { "type": "string" },
          "name": { "type": "string" },
          "slug": { "type": "string" },
          "brand": { "type": "string" },
          "priceCents": { "type": "number" },
          "oldPriceCents": { "type": "object", "nullable": true },
          "stock": { "type": "number" },
          "imageUrl": { "type": "object", "nullable": true }
        },
        "required": ["id", "name", "slug", "brand", "priceCents", "stock"]
      },
      "CartItemDto": {
        "type": "object",
        "properties": {
          "id": { "type": "string" },
          "productId": { "type": "string" },
          "quantity": { "type": "number" },
          "unitPriceCents": { "type": "number" },
          "totalCents": { "type": "number" },
          "product": { "$ref": "#/components/schemas/CartProductDto" }
        },
        "required": [
          "id",
          "productId",
          "quantity",
          "unitPriceCents",
          "totalCents",
          "product"
        ]
      },
      "CartSummaryDto": {
        "type": "object",
        "properties": {
          "itemsCount": { "type": "number" },
          "totalQuantity": { "type": "number" },
          "subtotalCents": { "type": "number" }
        },
        "required": ["itemsCount", "totalQuantity", "subtotalCents"]
      },
      "CartDto": {
        "type": "object",
        "properties": {
          "id": { "type": "string" },
          "isAnonymous": { "type": "boolean" },
          "items": {
            "type": "array",
            "items": { "$ref": "#/components/schemas/CartItemDto" }
          },
          "summary": { "$ref": "#/components/schemas/CartSummaryDto" }
        },
        "required": ["id", "isAnonymous", "items", "summary"]
      },
      "AddCartItemDto": {
        "type": "object",
        "properties": {
          "productId": { "type": "string" },
          "quantity": { "type": "number", "minimum": 1, "maximum": 99 }
        },
        "required": ["productId", "quantity"]
      },
      "UpdateCartItemDto": {
        "type": "object",
        "properties": {
          "quantity": { "type": "number", "minimum": 1, "maximum": 99 }
        },
        "required": ["quantity"]
      },
      "CsrfResponseDto": {
        "type": "object",
        "properties": { "csrfToken": { "type": "string" } },
        "required": ["csrfToken"]
      },
      "RegisterDto": {
        "type": "object",
        "properties": {
          "email": { "type": "string", "example": "demo@example.com" },
          "password": {
            "type": "string",
            "example": "password123",
            "minLength": 8
          },
          "name": { "type": "string", "example": "Тестовый пользователь" },
          "avatarUrl": {
            "type": "string",
            "example": "https://example.com/avatar.png"
          }
        },
        "required": ["email", "password", "name"]
      },
      "AuthUserDto": {
        "type": "object",
        "properties": {
          "id": { "type": "string" },
          "email": { "type": "string" },
          "name": { "type": "string" },
          "avatarUrl": { "type": "object", "nullable": true },
          "bonusBalanceCents": { "type": "number" },
          "role": { "type": "string" }
        },
        "required": ["id", "email", "name", "bonusBalanceCents", "role"]
      },
      "AuthResponseDto": {
        "type": "object",
        "properties": {
          "user": { "$ref": "#/components/schemas/AuthUserDto" }
        },
        "required": ["user"]
      },
      "LoginDto": {
        "type": "object",
        "properties": {
          "email": { "type": "string", "example": "demo@example.com" },
          "password": {
            "type": "string",
            "example": "password123",
            "minLength": 8
          }
        },
        "required": ["email", "password"]
      }
    }
  }
}
