              "application/json": {
                "schema": { "$ref": "#/components/schemas/ProductDto" }
              }
            }
          }
        },
        "tags": ["catalog"]
      }
    },
    "/api/v1/cart": {
      "get": {
        "operationId": "CartController_getCart",
        "parameters": [],
        "responses": {
          "200": {
            "description": "",
            "content": {
              "application/json": {
                "schema": { "$ref": "#/components/schemas/CartDto" }
              }
            }
          }
        },
        "tags": ["cart"]
      },
      "delete": {
        "operationId": "CartController_clearCart",
